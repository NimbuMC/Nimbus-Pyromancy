	"description": "This is Minecraft Fabric Pyromancy mod by Nimbu.",
	"authors": [
		"Nimbu"
	],
	"contact": {
		"homepage": "",
		"sources": "https://github.com/NimbuMC/Nimbus-Pyromancy"
	},
	"license": "Apache-2.0",
